# Backend
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change-me-to-another-random-64-char-string
REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# CORS
FRONTEND_URL=http://localhost:3000

# Content path (relative to backend root)
CONTENT_PATH=../content

# Email (Resend)
RESEND_API_KEY=re_YOUR_KEY_HERE
EMAIL_FROM=noreply@candydaysdz.com

# Cloudflare R2 (Object Storage)
R2_ACCOUNT_ID=YOUR_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_ACCESS_KEY
R2_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
R2_BUCKET_NAME=candy-days-assets
R2_PUBLIC_URL=https://YOUR_BUCKET.r2.dev

# Rate limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=30
